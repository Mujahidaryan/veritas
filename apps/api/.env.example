# ─── Server ───────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://veritas:veritas_dev@localhost:5432/veritas_db

# ─── Redis ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_64
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ─── QR / Verification ────────────────────────────────
# Generate with: openssl rand -hex 32
QR_HMAC_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
VERIFICATION_BASE_URL=http://localhost:3001

# ─── Hyperledger Fabric ───────────────────────────────
FABRIC_CHANNEL=veritas-channel
FABRIC_CHAINCODE=document-registry
FABRIC_MSP_ID=VeritasMSP
FABRIC_PEER_ENDPOINT=localhost:7051
FABRIC_TLS_CERT_PATH=./infra/fabric/crypto/tls-cert.pem
FABRIC_CERT_PATH=./infra/fabric/crypto/cert.pem
FABRIC_KEY_PATH=./infra/fabric/crypto/key.pem

# ─── Google Cloud Storage ─────────────────────────────
GCS_PROJECT_ID=your-gcp-project-id
GCS_BUCKET=veritas-documents-dev
GOOGLE_APPLICATION_CREDENTIALS=./infra/gcp/service-account.json

# ─── Storage Encryption ───────────────────────────────
# Must be exactly 32 chars. Generate: openssl rand -base64 32 | head -c 32
STORAGE_ENCRYPTION_KEY=CHANGE_ME_EXACTLY_32_CHARS_HERE_X

# ─── Email (SMTP) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@veritas.io
SMTP_PASS=your-app-password
SMTP_FROM=Veritas <noreply@veritas.io>

# ─── CORS ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Rate Limiting ────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
